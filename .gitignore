# ============================================================
# Donor Intelligence & Fundraising Analytics
# .gitignore
# ============================================================

# ------------------------------------------------------------
# Python Cache
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
venv/
.venv/
env/

# ------------------------------------------------------------
# VS Code
# ------------------------------------------------------------
.vscode/

# ------------------------------------------------------------
# Jupyter Notebook
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
output/logs/

# ------------------------------------------------------------
# Python Environment Files
# ------------------------------------------------------------
.python-version

# ------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Build / Distribution
# ------------------------------------------------------------
build/
dist/
*.egg-info/

# ------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------
*.tmp
*.bak
*.swp

# ------------------------------------------------------------
# Test Cache
# ------------------------------------------------------------
.pytest_cache/

# ------------------------------------------------------------
# IDE Settings
# ------------------------------------------------------------
.idea/

# ============================================================
# NOTE:
# We intentionally DO NOT ignore:
#
# output/charts/
# output/cleaned_data.csv
# output/donor_dashboard.html
# output/donor_analytics_report.html
#
# These are project outputs that showcase the work and are
# useful for your GitHub portfolio.
# ============================================================